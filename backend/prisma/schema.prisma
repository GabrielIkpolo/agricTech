generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  FARMER
  BUYER
  DRIVER
  AGENT
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  email         String    @unique
  password      String
  role          Role      @default(FARMER)
  phoneNumber   String?
  address       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Agent relationship: If user is a farmer, they might have an agent
  agentId       String?   @db.ObjectId
  agent         User?     @relation("AgentFarmers", fields: [agentId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  farmers       User[]    @relation("AgentFarmers")

  // Relationships for roles
  products      Product[] // Only if FARMER
  ordersAsBuyer Order[]   @relation("ordersAsBuyer") // Only if BUYER
  ordersAsSeller Order[]  @relation("ordersAsSeller") // Only if FARMER
}

model Product {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   // e.g., "Maize", "Yam"
  description String?
  quantity    Float    // in kg or bags
  unit        String   // e.g., "kg", "bag"
  price       Float    // price per unit
  category    String   // e.g., "Grains", "Tubers"
  location    String   // Where the produce is located
  status      String   @default("AVAILABLE") // AVAILABLE, SOLD, RESERVED
  
  farmerId    String   @db.ObjectId
  farmer      User     @relation(fields: [farmerId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  
  orders      Order[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  productId     String   @db.ObjectId
  product       Product  @relation(fields: [productId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  
  buyerId       String   @db.ObjectId
  buyer         User     @relation("ordersAsBuyer", fields: [buyerId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  
  sellerId      String   @db.ObjectId
  seller        User     @relation("ordersAsSeller", fields: [sellerId], references: [id], onUpdate: NoAction, onDelete: NoAction)
  
  quantity      Float
  totalPrice    Float
  status        String   @default("PENDING") // PENDING, PAID, SHIPPED, DELIVERED, CANCELLED
  paymentStatus String   @default("UNPAID") // UNPAID, HELD_IN_ESCROW, RELEASED
  
  driverId      String?  @db.ObjectId // To be assigned later
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
